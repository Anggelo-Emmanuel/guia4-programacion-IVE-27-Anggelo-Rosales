Algoritmo act4_lecc22_inciso1
	Definir num, i, resultado Como Entero
	
    Escribir "Ingrese un numero"
    Leer num
	
    Escribir "Tabla de multiplicar del ", num
    Escribir ""
	
    Para i = 1 Hasta 10 Hacer
		
        resultado = num * i
		
        Escribir num, " x ", i, " = ", resultado
		
    FinPara
	
FinAlgoritmo
